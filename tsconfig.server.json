{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/server",
    "rootDir": "./src/server",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/client"]
}
